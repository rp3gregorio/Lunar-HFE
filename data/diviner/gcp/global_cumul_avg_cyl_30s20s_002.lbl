PDS_VERSION_ID               = PDS3

RECORD_TYPE                  = FIXED_LENGTH
RECORD_BYTES                 = 113
FILE_RECORDS                 = 1382401

DESCRIPTION                  = "This table contains brightness temperatures
                                and bolometric brightness temperatures from
                                the Diviner Lunar Radiometer Experiment
                                binned at 0.5 degree latitude and longitude
                                and 0.25 hours of local time derived from a
                                compilation of all nadir observations acquired
                                from 5-July-2009 to 1-April-2015. Negative
                                brightness temperatures result from negative
                                radiance values obtained by a sensor when
                                temperatures are below the sensitivity of a
                                Diviner channel. Constant -9999 corresponds to
                                bins that contained no observations.
                                For more information, please see:
                                Williams et al. (2017) 'The global surface
                                temperatures of the Moon as measured by
                                the Diviner Lunar Radiometer
                                Experiment', Icarus, 283, 300-325.
                               "
